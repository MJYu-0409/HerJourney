/* ── Page ─────────────────────────────────────────────────────────────────── */

.community-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ── Header ───────────────────────────────────────────────────────────────── */

.header {
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

.header-sub {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

/* ── Search ───────────────────────────────────────────────────────────────── */

.search-wrap {
  padding: 0 32rpx 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-card);
  border-radius: var(--radius-full);
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: var(--shadow-soft);
}

.search-icon {
  font-size: 32rpx;
  color: var(--text-hint);
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
  height: 100%;
}

.search-placeholder {
  color: var(--text-hint);
  font-size: var(--font-sm);
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-secondary);
}

.clear-icon {
  font-size: 28rpx;
  color: var(--text-hint);
  line-height: 1;
}

/* ── Tag Bar ──────────────────────────────────────────────────────────────── */

.tag-bar {
  padding: 0 32rpx 24rpx;
  white-space: nowrap;
}

.tag-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 8rpx;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: var(--font-sm);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  box-shadow: var(--shadow-soft);
}

.filter-tag.active {
  background: linear-gradient(135deg, #8E7AB5 0%, #A990CC 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(142, 122, 181, 0.3);
}

/* ── Post List ────────────────────────────────────────────────────────────── */

.post-list {
  padding: 16rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Post Card ────────────────────────────────────────────────────────────── */

.post-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #8E7AB5 0%, #E7C8D5 50%, #B8C7D9 100%);
  opacity: 0.3;
}

/* ── Card Header ──────────────────────────────────────────────────────────── */

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.emotion-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
}

.emotion-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.emotion-text {
  font-size: var(--font-xs);
}

.post-time {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* ── Title ────────────────────────────────────────────────────────────────── */

.post-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  letter-spacing: 1rpx;
}

/* ── Content ──────────────────────────────────────────────────────────────── */

.post-content-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.post-content {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.8;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: pre-wrap;
}

.post-content.expanded {
  -webkit-line-clamp: unset;
  display: block;
}

.expand-btn {
  font-size: var(--font-xs);
  color: var(--color-brand);
  align-self: flex-start;
  padding: 4rpx 0;
}

/* ── Meta Row ─────────────────────────────────────────────────────────────── */

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.stage-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  color: var(--color-brand);
  font-size: var(--font-xs);
}

.symptom-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  background: #F3E9DF;
  color: #A08070;
  font-size: var(--font-xs);
}

/* ── Tag Row ──────────────────────────────────────────────────────────────── */

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hash-tag {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* ── Interaction Bar ──────────────────────────────────────────────────────── */

.interaction-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 20rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid rgba(142, 122, 181, 0.08);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  transition: all 0.25s ease;
}

.action-btn:active {
  background: rgba(142, 122, 181, 0.08);
}

.action-btn.active {
  background: rgba(142, 122, 181, 0.1);
}

.action-btn.active .action-text {
  color: var(--color-brand);
  font-weight: 500;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-symbol {
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1;
}

.action-btn.active .icon-symbol {
  color: var(--color-brand);
}

.action-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.action-count {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-left: 2rpx;
}

.action-btn.active .action-count {
  color: var(--color-brand);
}

/* ── Safe Bottom ──────────────────────────────────────────────────────────── */

.safe-bottom {
  height: 40rpx;
}

/* ── Empty State ──────────────────────────────────────────────────────────── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.empty-sub {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* ── Dark Theme ────────────────────────────────────────────────────────────── */

.dark .symptom-tag {
  background: #3D3550;
  color: #B8B0C5;
}

.dark .post-card::before {
  opacity: 0.15;
}
