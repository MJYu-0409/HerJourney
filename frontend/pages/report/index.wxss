/* ── Page ─────────────────────────────────────────────────────────────────── */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 24rpx 32rpx 0;
}

/* ── Cards ────────────────────────────────────────────────────────────────── */

.section-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  padding: 32rpx;
  overflow: hidden;
}

/* ── Chart section ────────────────────────────────────────────────────────── */

.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.symptom-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 10rpx 24rpx;
}
.symptom-btn:active { opacity: 0.7; }

.symptom-btn-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.symptom-btn-arrow {
  font-size: 24rpx;
  color: var(--color-brand);
}

/* Time range tabs */
.time-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.time-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background: var(--bg-secondary);
  font-weight: 500;
}

.time-tab.active {
  background: var(--color-brand);
  color: #FFFFFF;
}
.time-tab:active { opacity: 0.75; }

/* Custom date picker */
.custom-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.custom-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.date-pick-btn {
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 10rpx 24rpx;
  font-size: var(--font-sm);
  color: var(--color-brand);
  font-weight: 500;
}

/* Legend */
.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 28rpx;
  margin-bottom: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-name {
  font-size: var(--font-sm);
  color: var(--text-primary);
}

/* No data */
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: var(--font-sm);
  color: var(--text-hint);
}

/* ── AI Card ──────────────────────────────────────────────────────────────── */

.ai-card {
  background: linear-gradient(135deg, #F5F3F8 0%, #FFF5F8 100%);
  border: 1rpx solid rgba(180, 165, 204, 0.3);
}

.ai-card-header {
  margin-bottom: 24rpx;
}

.ai-badge {
  display: inline-block;
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-brand);
  background: rgba(123, 108, 160, 0.12);
  border-radius: var(--radius-full);
  padding: 8rpx 24rpx;
}

/* Typing dots animation */
.typing-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  animation: bounce 1.2s infinite ease-in-out;
}
.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
  40%            { transform: translateY(-8rpx); opacity: 1; }
}

.typing-hint {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.ai-content {
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.8;
  display: block;
}

.ai-empty {
  font-size: var(--font-sm);
  color: var(--text-hint);
  display: block;
  padding: 8rpx 0;
}

.regen-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 32rpx;
  padding: 20rpx 0;
  border: 2rpx solid var(--color-brand);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-brand);
}
.regen-btn:active { background: rgba(123, 108, 160, 0.08); }

.regen-icon { font-size: 28rpx; }

/* ── Symptom picker bottom sheet ─────────────────────────────────────────── */

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 100;
}

.picker-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0, 0.14, 1);
}

.picker-sheet.show { transform: translateY(0); }

.picker-handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #D8D2E4;
  margin: 20rpx auto 0;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx 16rpx;
}

.picker-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.picker-confirm {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-brand);
  padding: 8rpx 16rpx;
}
.picker-confirm:active { opacity: 0.7; }

.picker-body {
  flex: 1;
  overflow: hidden;
  padding: 16rpx 40rpx 32rpx;
}

.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.symptom-chip {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background: var(--bg-secondary);
  border: 2rpx solid transparent;
}

.symptom-chip.selected {
  color: var(--color-brand);
  background: rgba(123, 108, 160, 0.1);
  border-color: var(--color-brand);
  font-weight: 600;
}
.symptom-chip:active { opacity: 0.7; }
