/* ── 页面 ──────────────────────────────────────────────────────────────────── */

.page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 24rpx 32rpx 0;
}

.section-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* ── 头像区 ───────────────────────────────────────────────────────────────── */

.avatar-section {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-default {
  background: linear-gradient(135deg, #C6B4E1 0%, #E7C8D5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-char {
  font-size: 72rpx;
  font-weight: 600;
  color: #fff;
}

.avatar-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* ── 表单 ─────────────────────────────────────────────────────────────────── */

.form-card { padding: 8rpx 0; }

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(142,122,181,0.08);
}
.form-item:last-child { border-bottom: none; }

.form-label {
  width: 160rpx;
  font-size: var(--font-base);
  color: var(--text-primary);
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--text-primary);
  text-align: right;
}

.form-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.form-picker-text {
  font-size: var(--font-base);
  color: var(--text-primary);
}

.form-picker-text.placeholder {
  color: var(--text-hint);
}

.form-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* ── 保存按钮 ─────────────────────────────────────────────────────────────── */

.save-wrap {
  margin-top: 48rpx;
  padding: 0 16rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(142,122,181,0.3);
}
.save-btn:active { opacity: 0.9; }
.save-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.save-btn text {
  font-size: var(--font-md);
  font-weight: 600;
  color: #fff;
}

/* ── 加载动画 ─────────────────────────────────────────────────────────────── */

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.btn-spinner .spinner {
  border-top-color: #fff;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
