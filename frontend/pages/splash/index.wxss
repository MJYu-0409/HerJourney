.splash {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 380rpx 60rpx 180rpx;
  background: linear-gradient(180deg, #F8F7FA 0%, #F0EDF5 50%, #EBE6F2 100%);
  overflow: hidden;
}

/* 极弱的环境光晕，只做氛围不做主角 */
.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(140rpx);
  opacity: 0.18;
  pointer-events: none;
}

.glow-1 {
  width: 600rpx;
  height: 600rpx;
  background: #B4A5CC;
  top: -120rpx;
  right: -180rpx;
}

.glow-2 {
  width: 500rpx;
  height: 500rpx;
  background: #C8B8CC;
  bottom: 280rpx;
  left: -160rpx;
}

/* Logo */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.brand-name {
  font-size: 80rpx;
  font-weight: 600;
  color: #4A4458;
  letter-spacing: 6rpx;
}

.brand-slogan {
  font-size: 30rpx;
  color: #9B94A8;
  letter-spacing: 6rpx;
}

/* 底部 */
.bottom {
  margin-top: auto;
  width: 100%;
  display: flex;
  justify-content: center;
}

.enter-btn {
  width: 480rpx;
  height: 96rpx;
  border-radius: 9999rpx;
  background: #7B6CA0;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(123, 108, 160, 0.28);
}

