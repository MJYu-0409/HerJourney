.splash {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 160rpx 60rpx 100rpx;
  background: var(--bg-primary);
  overflow: hidden;
}

/* 柔和背景光晕 */
.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.45;
  pointer-events: none;
}

.glow-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, #C6B4E1 0%, transparent 70%);
  top: -80rpx;
  right: -100rpx;
  animation: floatGlow 6s ease-in-out infinite alternate;
}

.glow-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, #E7C8D5 0%, transparent 70%);
  bottom: 160rpx;
  left: -80rpx;
  animation: floatGlow 8s ease-in-out infinite alternate-reverse;
}

@keyframes floatGlow {
  from { transform: translateY(0rpx) scale(1); }
  to   { transform: translateY(30rpx) scale(1.08); }
}

/* Logo */
.brand {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.brand-name {
  font-size: 88rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 12rpx;
}

.brand-slogan {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  letter-spacing: 4rpx;
}

/* 底部 */
.bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.enter-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, #8E7AB5 0%, #A990CC 100%);
  color: #fff;
  font-size: var(--font-base);
  font-weight: 500;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(142, 122, 181, 0.35);
  active-opacity: 0.85;
}

