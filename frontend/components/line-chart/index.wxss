.chart-wrap {
  position: relative;
  width: 100%;
  height: 220px;
}

.chart-canvas {
  display: block;
  width: 100%;
  height: 220px;
}

.tooltip {
  position: absolute;
  background: #FFFFFF;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(123, 108, 160, 0.2);
  padding: 10px 14px;
  min-width: 130px;
  z-index: 10;
  pointer-events: none;
}

.tip-date {
  font-size: 13px;
  font-weight: 600;
  color: #5A4A80;
  margin-bottom: 8px;
}

.tip-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 5px;
}

.tip-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.tip-name {
  font-size: 12px;
  color: #7B7385;
  flex: 1;
}

.tip-val {
  font-size: 12px;
  font-weight: 600;
  color: #5A4A80;
  min-width: 14px;
  text-align: right;
}
